# @plugin(@varlock/pass-plugin@0.0.6)
# @initPass()
# ---

POSTGRES_PASSWORD=pass("docker/bun-start/POSTGRES_PASSWORD")
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=disable"
S3_ACCESS_KEY_ID=pass("docker/bun-start/S3_ACCESS_KEY_ID")
S3_SECRET_ACCESS_KEY=pass("docker/bun-start/S3_SECRET_ACCESS_KEY")

